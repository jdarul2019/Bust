  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=120%><b><color=#FFD700>HOW TO PLAY: COIN FLIP</color></b></size>\r\n\r\nThe
    simplest game in the house. Pick a side, place your bet, and let fate decide.\r\n\r\n<b><color=#00FFFF>THE
    RULES:</color></b>\r\n\u2022 Press <b>HEADS</b> or <b>TAILS</b> to choose which
    side you think will land face up.\r\n\u2022 Set your wager using the chip buttons
    or the input field.\r\n\u2022 Press <b>FLIP</b>.\r\n\u2022 If your chosen side
    matches the result, you <color=#00FF00><b>WIN (x2 Payout)</b></color>!\r\n\u2022
    If the other side lands up, you <color=#FF0000><b>LOSE</b></color> your bet.\r\n\r\n<b><color=#FFCC00>PAYOUT
    TABLE:</color></b>\r\n  Correct guess  \u2192  <color=#00FF00><b>x2 your bet</b></color>\r\n 
    Wrong guess    \u2192  <color=#FF0000><b>Lose your bet</b></color>\r\n\r\n<b><color=#FFCC00>TIPS:</color></b>\r\n\u2022
    There's a perfect <b>50/50</b> chance on every flip \u2014 pure luck, no strategy
    needed!\r\n\r\n<i><size=80%>Note: Every flip costs 1 Energy.</size></i>\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: c579a803aac6cb24184fb3cb064f1215, type: 2}
