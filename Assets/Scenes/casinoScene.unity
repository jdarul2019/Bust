  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=120%><b>HOW TO PLAY BLACKJACK</b></size>\r\n\r\n1. <b>Build Bet:</b>
    Click the chip buttons (5, 10, 20, 50) to build your total bet amount.\r\n2.
    <b>Deal:</b> Click the <color=#FFA500><b>DEAL</b></color> button to receive your
    initial cards.\r\n<i>Note: Every deal costs <color=yellow>5 Energy</color>.</i>\r\n3.
    <b>Player Actions:</b>\r\n   \u2022 <b>Hit:</b> Draw another card to increase
    your score. Don't go over 21 (Bust)!\r\n   \u2022 <b>Stand:</b> Keep your current
    cards and pass the turn to the Dealer.\r\n   \u2022 <b>Double:</b> Double your
    bet, receive exactly one more card, and pass the turn.\r\n   \u2022 <b>Split:</b>
    If your first two cards have the same value, split them into two separate hands
    (requires an equal additional bet).\r\n4. <b>Clear Bet:</b> Made a mistake? Use
    the Clear button before dealing to reset your chips.\r\n\r\n<size=110%><b>CARD
    VALUES:</b></size>\r\n\u2022 <b>Numbers (2-10):</b> Face value\r\n\u2022 <b>Face
    Cards (J, Q, K):</b> 10 points\r\n\u2022 <b>Ace:</b> 1 or 11 points (whichever
    is better)\r\n\r\n<size=110%><b>PAYOUTS:</b></size>\r\n\u2022 <b>Standard Win</b>
    = <color=green><b>x2</b></color>\r\n\u2022 <b>Natural Blackjack (21 on first
    2 cards)</b> = <color=green><b>x2.5</b></color>\r\n\u2022 <b>Push (Tie)</b> =
    <color=yellow><b>Bet Returned</b></color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: c579a803aac6cb24184fb3cb064f1215, type: 2}
  m_sharedMaterial: {fileID: 431081014000995018, guid: c579a803aac6cb24184fb3cb064f1215, type: 2}
