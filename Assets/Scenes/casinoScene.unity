  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=120%><b>HOW TO PLAY ROULETTE</b></size>\n\n1. <b>Select Chip:</b>
    Click the chip buttons at the bottom (5, 10, 20, 50) to build your bet amount.\n2.
    <b>Place Bets:</b> Click on the betting zones on the board (e.g., Red/Black,
    Even/Odd, 1st 12) to place your selected chips.\n3. <b>Spin:</b> Click the <color=#FFA500><b>SPIN</b></color>
    button to roll the ball.\n<i>Note: Every spin costs <color=yellow>5 Energy</color>.</i>\n4.
    <b>Clear Bet:</b> Made a mistake? Use the Reset button to clear your selected
    chips or the board.\n\n<size=110%><b>PAYOUTS:</b></size>\n\u2022 <b>Red / Black</b>
    = <color=green><b>x2</b></color>\n\u2022 <b>Even / Odd</b> = <color=green><b>x2</b></color>\n\u2022
    <b>1-18 / 19-36</b> = <color=green><b>x2</b></color>\n\u2022 <b>Rows (2/1)</b>
    = <color=green><b>x3</b></color>\n\u2022 <b>Dozens (1st, 2nd, 3rd 12)</b> = <color=green><b>x3</b></color>\n\u2022
    <b>Exact number</b> = <color=green><b>x35</b></color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: c579a803aac6cb24184fb3cb064f1215, type: 2}
